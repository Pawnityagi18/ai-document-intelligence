\"\"\"Configuration management for the application\"\"\"\n\nfrom pydantic_settings import BaseSettings\nfrom typing import Optional, Literal\n\n\nclass Settings(BaseSettings):\n    \"\"\"Application settings loaded from environment variables\"\"\"\n\n    # LLM Configuration - Choose \"openai\" or \"ollama\"\n    llm_provider: Literal[\"openai\", \"ollama\"] = \"ollama\"  # Use ollama by default (free!)\n    openai_api_key: Optional[str] = None  # Optional if using ollama\n    openai_model: str = \"gpt-3.5-turbo\"\n    \n    # Ollama Configuration (FREE - runs locally)\n    ollama_base_url: str = \"http://127.0.0.1:11434\"\n    ollama_model: str = \"mistral\"  # Fast and free model\n    \n    # Embedding Configuration - Choose \"openai\" or \"ollama\"\n    embedding_provider: Literal[\"openai\", \"ollama\"] = \"ollama\"  # Use ollama by default (free!)\n    embedding_model: str = \"nomic-embed-text\"  # Free local embedding model\n\n    # Application Configuration\n    chunk_size: int = 500\n    chunk_overlap: int = 50\n    top_k_results: int = 3\n    confidence_threshold: float = 0.5\n\n    # Database Configuration\n    chroma_db_path: str = \"./data/chroma_db\"\n    chroma_collection_name: str = \"documents\"\n\n    # Server Configuration\n    debug: bool = True\n    log_level: str = \"INFO\"\n    max_upload_size_mb: int = 10\n\n    # CORS Configuration\n    allowed_origins: list = [\"*\"]\n\n    class Config:\n        \"\"\"Pydantic config\"\"\"\n        env_file = \".env\"\n        env_file_encoding = \"utf-8\"\n        case_sensitive = False\n\n\n# Create global settings instance\nsettings = Settings()\n", "path": "app/config.py", "sha": "1641066cf7aab744dc0b99b56b0fa1f5036b328c"}, {"content": "\"\"\"Embedding generation service with OpenAI and Ollama support\"\"\"\n\nimport logging\nfrom typing import List\nfrom datetime import datetime\nfrom app.config import settings\nfrom app.utils.errors import EmbeddingError\nfrom app.models.domain import EmbeddingCacheEntry\n\nlogger = logging.getLogger(__name__)\n\n\nclass EmbeddingService:\n    \"\"\"Generate embeddings for text\"\"\"\n\n    def __init__(self):\n        \"\"\"Initialize embedding service\"\"\"\n        self.provider = settings.embedding_provider\n        self.cache: dict[str, EmbeddingCacheEntry] = {}\n        \n        if self.provider == \"openai\":\n            import openai\n            openai.api_key = settings.openai_api_key\n            self.model = settings.embedding_model\n            logger.info(f\"Using OpenAI embeddings: {self.model}\")\n        else:\n            # Using Ollama\n            self.base_url = settings.ollama_base_url\n            self.model = settings.embedding_model\n            logger.info(f\"Using Ollama embeddings: {self.model} at {self.base_url}\")\n            logger.info(\"✅ FREE - Running locally on your machine!\")\n\n    def generate_embedding(self, text: str) -> List[float]:\n        \"\"\"Generate embedding for a text string\n\n        Args:\n            text: Text to embed\n\n        Returns:\n            Embedding vector\n\n        Raises:\n            EmbeddingError: If embedding generation fails\n        \"\"\"\n        try:\n            # Check cache\n            if text in self.cache:\n                logger.debug(f\"Cache hit for embedding\")\n                return self.cache[text].embedding\n\n            logger.debug(f\"Generating embedding for text length: {len(text)}\")\n\n            if self.provider == \"openai\":\n                embedding = self._generate_openai_embedding(text)\n            else:\n                embedding = self._generate_ollama_embedding(text)\n\n            # Cache the embedding\n            self.cache[text] = EmbeddingCacheEntry(\n                text=text,\n                embedding=embedding,\n                created_at=datetime.now()\n            )\n\n            logger.debug(f\"Generated embedding: dimension={len(embedding)}\")\n            return embedding\n\n        except Exception as e:\n            error_msg = f\"Failed to generate embedding: {str(e)}\"\n            logger.error(error_msg)\n            raise EmbeddingError(error_msg) from e\n\n    def _generate_openai_embedding(self, text: str) -> List[float]:\n        \"\"\"Generate embedding using OpenAI API\"\"\"\n        import openai\n        response = openai.Embedding.create(\n            input=text,\n            model=self.model\n        )\n        return response[\"data\"][0][\"embedding\"]\n\n    def _generate_ollama_embedding(self, text: str) -> List[float]:\n        \"\"\"Generate embedding using Ollama (FREE, local)\"\"\"\n        import requests\n        response = requests.post(\n            f\"{self.base_url}/api/embeddings\",\n            json={\"model\": self.model, \"prompt\": text},\n            timeout=60\n        )\n        if response.status_code != 200:\n            raise EmbeddingError(\n                f\"Ollama error: {response.status_code} - {response.text}. \"\n                f\"Make sure Ollama is running: ollama serve\"\n            )\n        return response.json()[\"embedding\"]\n\n    def generate_embeddings(self, texts: List[str]) -> List[List[float]]:\n        \"\"\"Generate embeddings for multiple texts\n\n        Args:\n            texts: List of texts to embed\n\n        Returns:\n            List of embedding vectors\n\n        Raises:\n            EmbeddingError: If embedding generation fails\n        \"\"\"\n        logger.info(f\"Generating {len(texts)} embeddings (FREE - using {self.provider})\")\n        embeddings = []\n\n        for i, text in enumerate(texts):\n            try:\n                embedding = self.generate_embedding(text)\n                embeddings.append(embedding)\n                if (i + 1) % 10 == 0:\n                    logger.info(f\"Generated {i + 1}/{len(texts)} embeddings\")\n            except EmbeddingError:\n                logger.error(f\"Failed to embed text {i}\")\n                raise\n\n        logger.info(f\"Successfully generated {len(embeddings)} embeddings\")\n        return embeddings\n\n    def clear_cache(self) -> None:\n        \"\"\"Clear embedding cache\"\"\"\n        cache_size = len(self.cache)\n        self.cache.clear()\n        logger.info(f\"Cleared embedding cache ({cache_size} entries)\")\n", "path": "app/services/embedding_service.py", "sha": "d163d14aaa5ae4c3a94d31f6a231bf404727f2f8"}, {"content": "\"\"\"LLM service for answer generation with OpenAI and Ollama support\"\"\"\n\nimport logging\nfrom typing import List, Tuple\nfrom app.config import settings\nfrom app.utils.errors import LLMError\n\nlogger = logging.getLogger(__name__)\n\n\nclass LLMService:\n    \"\"\"Generate answers using LLM (OpenAI or Ollama)\"\"\"\n\n    def __init__(self):\n        \"\"\"Initialize LLM service\"\"\"\n        self.provider = settings.llm_provider\n        \n        if self.provider == \"openai\":\n            import openai\n            openai.api_key = settings.openai_api_key\n            self.model = settings.openai_model\n            logger.info(f\"Using OpenAI LLM: {self.model}\")\n        else:\n            # Using Ollama\n            self.base_url = settings.ollama_base_url\n            self.model = settings.ollama_model\n            logger.info(f\"Using Ollama LLM: {self.model} at {self.base_url}\")\n            logger.info(\"✅ FREE - Running locally on your machine!\")\n\n    def generate_answer(\n        self,\n        question: str,\n        context: str\n    ) -> Tuple[str, float]:\n        \"\"\"Generate answer based on context\n\n        Args:\n            question: User question\n            context: Retrieved context from vector store\n\n        Returns:\n            Tuple of (answer, confidence_score)\n\n        Raises:\n            LLMError: If generation fails\n        \"\"\"\n        try:\n            logger.info(f\"Generating answer for question: {question[:50]}...\")\n\n            system_prompt = (\n                \"You are a helpful assistant that answers questions based on \"\n                \"the provided document context. \"\n                \"\\n\\nRules:\"\n                \"\\n1. Be concise and direct. Start with the answer immediately.\"\n                \"\\n2. If the answer is not in the context, explicitly say \"\n                \"'I don't know' and explain what information is missing.\"\n                \"\\n3. If you're uncertain, express that uncertainty.\"\n                \"\\n4. Use the context to support your answer with specific details.\"\n            )\n\n            user_message = (\n                f\"Document Context:\\n{context}\\n\\n\"\n                f\"Question: {question}\\n\\n\"\n                f\"Answer:\"\n            )\n\n            if self.provider == \"openai\":\n                answer, confidence = self._generate_openai_answer(\n                    system_prompt, user_message\n                )\n            else:\n                answer, confidence = self._generate_ollama_answer(\n                    system_prompt, user_message\n                )\n\n            logger.info(\n                f\"Generated answer (confidence: {confidence:.2f}): \"\n                f\"{answer[:50]}...\"\n            )\n            return answer, confidence\n\n        except Exception as e:\n            error_msg = f\"Failed to generate answer: {str(e)}\"\n            logger.error(error_msg)\n            raise LLMError(error_msg) from e\n\n    def _generate_openai_answer(\n        self, system_prompt: str, user_message: str\n    ) -> Tuple[str, float]:\n        \"\"\"Generate answer using OpenAI API\"\"\"\n        import openai\n        response = openai.ChatCompletion.create(\n            model=self.model,\n            messages=[\n                {\"role\": \"system\", \"content\": system_prompt},\n                {\"role\": \"user\", \"content\": user_message}\n            ],\n            temperature=0.7,\n            max_tokens=500\n        )\n        answer = response[\"choices\"][0][\"message\"][\"content\"].strip()\n        \n        # Estimate confidence\n        is_confident = (\n            \"i don't know\" not in answer.lower() and \n            \"cannot answer\" not in answer.lower() and\n            len(answer) > 50\n        )\n        confidence = 0.8 if is_confident else 0.2\n        return answer, confidence\n\n    def _generate_ollama_answer(\n        self, system_prompt: str, user_message: str\n    ) -> Tuple[str, float]:\n        \"\"\"Generate answer using Ollama (FREE, local)\"\"\"\n        import requests\n        \n        # Combine system prompt and user message\n        full_message = f\"{system_prompt}\\n\\n{user_message}\"\n        \n        response = requests.post(\n            f\"{self.base_url}/api/generate\",\n            json={\n                \"model\": self.model,\n                \"prompt\": full_message,\n                \"stream\": False,\n                \"temperature\": 0.7\n            },\n            timeout=300  # 5 minutes timeout for local inference\n        )\n        \n        if response.status_code != 200:\n            raise LLMError(\n                f\"Ollama error: {response.status_code} - {response.text}. \"\n                f\"Make sure Ollama is running: ollama serve\"\n            )\n        \n        answer = response.json()[\"response\"].strip()\n        \n        # Estimate confidence\n        is_confident = (\n            \"i don't know\" not in answer.lower() and \n            \"cannot answer\" not in answer.lower() and\n            len(answer) > 50\n        )\n        confidence = 0.8 if is_confident else 0.2\n        return answer, confidence\n\n    def count_tokens(\n        self,\n        text: str\n    ) -> int:\n        \"\"\"Estimate token count for text\n\n        Args:\n            text: Text to count tokens for\n\n        Returns:\n            Estimated token count\n        \"\"\"\n        # Rough estimate: 1 token ≈ 4 characters\n        return max(1, len(text) // 4)\n", "path": "app/services/llm_service.py", "sha": "d163d14aaa5ae4c3a94d31f6a231bf404727f2f8"}, {"content": "# OpenAI Configuration (LEAVE BLANK if using Ollama - it's FREE!)\nOPENAI_API_KEY=\n\n# LLM Provider: \"openai\" or \"ollama\" (use ollama for FREE local models)\nLLM_PROVIDER=ollama\n\n# Ollama Configuration (FREE - runs locally on your machine)\nOLLAMA_BASE_URL=http://127.0.0.1:11434\nOLLAMA_MODEL=mistral\n\n# Embedding Provider: \"openai\" or \"ollama\" (use ollama for FREE local embeddings)\nEMBEDDING_PROVIDER=ollama\nEMBEDDING_MODEL=nomic-embed-text\n\n# Application Configuration\nCHUNK_SIZE=500\nCHUNK_OVERLAP=50\nTOP_K_RESULTS=3\nCONFIDENCE_THRESHOLD=0.5\n\n# FastAPI Configuration\nDEBUG=True\nLOG_LEVEL=INFO\n\n# Vector Store\nCHROMA_DB_PATH=./data/chroma_db\nCHROMA_COLLECTION_NAME=documents\n\n# CORS Configuration (for development)\nALLOWED_ORIGINS=[\"*\"]\n", "path": ".env.example", "sha": "7e082e0dd4a4e2bed5b8cc7f080bb251b072dcb4"}]